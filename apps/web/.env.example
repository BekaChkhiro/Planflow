# =============================================================================
# PlanFlow Web - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
#
# For production deployments, see .env.production.example
#
# Note: Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# Never put secrets in NEXT_PUBLIC_ variables!
# =============================================================================

# =============================================================================
# API CONFIGURATION - REQUIRED
# =============================================================================
# Backend API server URL
# Development: http://localhost:3001
# Production: https://api.your-domain.com
NEXT_PUBLIC_API_URL=http://localhost:3001

# =============================================================================
# APPLICATION CONFIGURATION - REQUIRED
# =============================================================================
# Frontend application URL
# Development: http://localhost:3000
# Production: https://app.your-domain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Application display name (shown in UI, emails, meta tags)
NEXT_PUBLIC_APP_NAME=PlanFlow

# =============================================================================
# WEBSOCKET CONFIGURATION
# =============================================================================
# WebSocket server URL for real-time updates
# Usually the same host as API but with ws:// or wss:// protocol
# Development: ws://localhost:3001
# Production: wss://api.your-domain.com
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# =============================================================================
# ANALYTICS (PostHog) - Optional
# =============================================================================
# Analytics tracking is disabled if not configured
# Get your project API key from https://app.posthog.com/project/settings

# PostHog project API key
NEXT_PUBLIC_POSTHOG_KEY=

# PostHog server host (default: https://app.posthog.com)
# Use EU host if required: https://eu.posthog.com
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# =============================================================================
# ERROR TRACKING (Sentry) - Optional
# =============================================================================
# Client-side error tracking is disabled if not configured

# Sentry DSN for client-side error reporting
# Get from https://sentry.io/settings/projects/
NEXT_PUBLIC_SENTRY_DSN=

# =============================================================================
# SENTRY BUILD CONFIGURATION - Optional (Server-side only)
# =============================================================================
# These are used during build for source map uploads
# Not prefixed with NEXT_PUBLIC_ as they should not be exposed to browser

# Auth token for source map uploads
# Get from https://sentry.io/settings/auth-tokens/
# SENTRY_AUTH_TOKEN=

# Organization slug (from Sentry dashboard URL)
# SENTRY_ORG=

# Project name in Sentry
# SENTRY_PROJECT=

# =============================================================================
# PAYMENTS (LemonSqueezy) - Optional
# =============================================================================
# Payment features are disabled if not configured

# Store ID for generating checkout links
# Get from https://app.lemonsqueezy.com/settings/stores
NEXT_PUBLIC_LEMONSQUEEZY_STORE_ID=

# =============================================================================
# PUSH NOTIFICATIONS (Web Push) - Optional
# =============================================================================
# Browser push notifications are disabled if not configured
# Must match the VAPID_PUBLIC_KEY set in API .env
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# =============================================================================
# QUICK START CHECKLIST
# =============================================================================
# Minimum required for development:
# ✅ NEXT_PUBLIC_API_URL (points to running API server)
# ✅ NEXT_PUBLIC_APP_URL
# ✅ NEXT_PUBLIC_APP_NAME
#
# Recommended for full functionality:
# ⬜ NEXT_PUBLIC_WS_URL (for real-time updates)
# ⬜ NEXT_PUBLIC_POSTHOG_KEY (for analytics)
# ⬜ NEXT_PUBLIC_SENTRY_DSN (for error tracking)
# ⬜ NEXT_PUBLIC_LEMONSQUEEZY_STORE_ID (for payments)
# =============================================================================
