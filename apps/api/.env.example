# =============================================================================
# PlanFlow API - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# For production deployments, see .env.production.example
# =============================================================================

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
# Port the API server listens on
PORT=3001

# Environment mode: development, test, production
NODE_ENV=development

# =============================================================================
# DATABASE (Neon PostgreSQL) - REQUIRED
# =============================================================================
# Get your connection strings from https://console.neon.tech
#
# Format: postgresql://[user]:[password]@[host]/[database]?sslmode=require
#
# Direct connection - used for migrations and schema changes
DATABASE_URL=postgresql://user:password@ep-example-123456.us-east-2.aws.neon.tech/planflow?sslmode=require

# Pooled connection - recommended for serverless environments
# Uses Neon's connection pooling for better performance
# Get the "-pooler" endpoint from your Neon dashboard
DATABASE_URL_POOLED=postgresql://user:password@ep-example-123456-pooler.us-east-2.aws.neon.tech/planflow?sslmode=require

# =============================================================================
# AUTHENTICATION (JWT) - REQUIRED
# =============================================================================
# CRITICAL: JWT_SECRET must be at least 32 characters for security
# Generate a secure secret: openssl rand -base64 48
#
# ⚠️  The server will NOT start with:
#    - Missing JWT_SECRET
#    - JWT_SECRET shorter than 32 characters
#    - Common insecure values like "secret", "change-me", etc.
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars

# Token expiration in seconds (default: 86400 = 24 hours)
JWT_EXPIRATION=86400

# Refresh token expiration in seconds (default: 2592000 = 30 days)
REFRESH_TOKEN_EXPIRATION=2592000

# =============================================================================
# APPLICATION URLs
# =============================================================================
# Frontend application URL (used for email links, OAuth redirects)
APP_URL=http://localhost:3000

# API URL (used for generating API links)
API_URL=http://localhost:3001

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
# Comma-separated list of allowed origins (no spaces)
# In development, localhost origins are auto-allowed
# In production, this is REQUIRED
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# =============================================================================
# EMAIL SERVICE (Resend) - Optional
# =============================================================================
# Email notifications are disabled if not configured
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=

# Sender email address (must be verified domain in Resend)
# Format: "Display Name <email@domain.com>"
RESEND_FROM_EMAIL=PlanFlow <notifications@planflow.tools>

# =============================================================================
# PAYMENTS (LemonSqueezy) - Optional
# =============================================================================
# Payment features are disabled if not configured
# Get credentials from https://app.lemonsqueezy.com/settings/api

# API key for server-side operations
LEMON_SQUEEZY_API_KEY=

# Store ID (found in Store settings)
LEMON_SQUEEZY_STORE_ID=

# Product variant IDs for subscription plans
LEMON_SQUEEZY_PRO_VARIANT_ID=
LEMON_SQUEEZY_TEAM_VARIANT_ID=

# Webhook secret for signature verification
# Get from LemonSqueezy webhook settings
LEMON_SQUEEZY_WEBHOOK_SECRET=

# =============================================================================
# GITHUB OAUTH - Optional
# =============================================================================
# Enables "Continue with GitHub" authentication for login/registration
# AND GitHub integration for linking tasks to PRs/issues.
#
# Create an OAuth App at: https://github.com/settings/developers
#
# Setup steps:
# 1. Go to GitHub → Settings → Developer settings → OAuth Apps
# 2. Create new OAuth App
# 3. Set "Authorization callback URL" to match GITHUB_REDIRECT_URI below
# 4. Copy Client ID and Client Secret
#
# Required scopes (set automatically):
#   - repo: Full control of private repositories (for issues, PRs)
#   - user:email: Access user email addresses (for authentication)
#   - read:user: Read user profile data
#   - admin:repo_hook: Manage webhooks (for automatic webhook setup)

# OAuth Client ID (from GitHub OAuth App settings)
GITHUB_CLIENT_ID=

# OAuth Client Secret (from GitHub OAuth App settings)
GITHUB_CLIENT_SECRET=

# OAuth callback URL for INTEGRATION (linking repos, issues, PRs)
# This is handled by the API server
# Development: http://localhost:3001/integrations/github/callback
# Production: https://api.your-domain.com/integrations/github/callback
GITHUB_REDIRECT_URI=http://localhost:3001/integrations/github/callback

# OAuth callback URL for AUTHENTICATION (Login/Register with GitHub)
# This is handled by the frontend
# Development: http://localhost:3000/auth/github/callback
# Production: https://your-domain.com/auth/github/callback
GITHUB_AUTH_REDIRECT_URI=http://localhost:3000/auth/github/callback

# Webhook secret for PR merge → task status updates (T8.5)
# Generate: openssl rand -hex 32
# Configure webhook in repo settings with:
#   - Payload URL: https://your-api/webhooks/github
#   - Content type: application/json
#   - Events: Pull requests
GITHUB_WEBHOOK_SECRET=

# =============================================================================
# GOOGLE OAUTH - Optional
# =============================================================================
# Enables "Continue with Google" authentication for login/registration.
#
# Create OAuth credentials at: https://console.cloud.google.com/apis/credentials
#
# Setup steps:
# 1. Create a new project in Google Cloud Console (or use existing)
# 2. Go to APIs & Services → OAuth consent screen
#    - Configure consent screen (External for public apps, Internal for org)
#    - Add scopes: email, profile, openid
# 3. Go to APIs & Services → Credentials
# 4. Click "Create Credentials" → "OAuth 2.0 Client ID"
# 5. Select "Web application" as application type
# 6. Add authorized redirect URIs (MUST exactly match GOOGLE_REDIRECT_URI):
#    - Development: http://localhost:3000/auth/google/callback
#    - Production: https://your-domain.com/auth/google/callback
# 7. Copy Client ID and Client Secret
#
# Required scopes (set automatically):
#   - openid: Required for OpenID Connect
#   - email: Access user's email address
#   - profile: Access user's basic profile (name, picture)

# OAuth Client ID (from Google Cloud Console → Credentials)
GOOGLE_CLIENT_ID=

# OAuth Client Secret (from Google Cloud Console → Credentials)
GOOGLE_CLIENT_SECRET=

# OAuth callback URL (MUST exactly match "Authorized redirect URIs" in Google Console)
# Development: http://localhost:3000/auth/google/callback
# Production: https://your-domain.com/auth/google/callback
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# =============================================================================
# REDIS CONFIGURATION - Optional
# =============================================================================
# Redis is used for:
#   - Rate limiting across server instances
#   - Task lock persistence
#   - Session caching
#
# If not configured, falls back to in-memory storage (single instance only)
#
# Option 1: Connection URL (recommended for cloud: Upstash, Railway, Redis Cloud)
# REDIS_URL=redis://default:password@hostname:6379
# UPSTASH_REDIS_URL=rediss://default:password@hostname:6379

# Option 2: Individual connection parameters
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0
# REDIS_TLS=false

# Key prefix for all Redis keys (default: "planflow:")
# REDIS_KEY_PREFIX=planflow:

# =============================================================================
# RATE LIMITING
# =============================================================================
# Maximum requests per IP per window
RATE_LIMIT_MAX=100

# Window duration in milliseconds (default: 60000 = 1 minute)
RATE_LIMIT_WINDOW_MS=60000

# =============================================================================
# LOGGING
# =============================================================================
# Log level: debug, info, warn, error
# Use "debug" in development, "info" or "warn" in production
LOG_LEVEL=debug

# =============================================================================
# ERROR TRACKING (Sentry) - Optional
# =============================================================================
# Error tracking is disabled if not configured
# Get your DSN from https://sentry.io/settings/projects/
SENTRY_DSN=

# Force enable Sentry in development (for testing error tracking)
# SENTRY_ENABLED=true

# =============================================================================
# PUSH NOTIFICATIONS (Web Push) - Optional
# =============================================================================
# Browser push notifications are disabled if not configured
# Generate VAPID keys: npx web-push generate-vapid-keys

# VAPID public key (also needed in frontend)
VAPID_PUBLIC_KEY=

# VAPID private key (server only)
VAPID_PRIVATE_KEY=

# Contact email for push service providers
VAPID_SUBJECT=mailto:support@planflow.tools

# =============================================================================
# QUICK START CHECKLIST
# =============================================================================
# Minimum required for development:
# ✅ DATABASE_URL or DATABASE_URL_POOLED
# ✅ JWT_SECRET (min 32 characters)
#
# Recommended for full functionality:
# ⬜ RESEND_API_KEY (for email notifications)
# ⬜ LEMON_SQUEEZY_* (for payment features)
# ⬜ REDIS_URL (for rate limiting in multi-instance deployments)
#
# OAuth Authentication (at least one recommended for easier sign-up):
# ⬜ GITHUB_CLIENT_ID + GITHUB_CLIENT_SECRET + GITHUB_REDIRECT_URI
#    → Enables "Continue with GitHub" + GitHub repo integration
# ⬜ GOOGLE_CLIENT_ID + GOOGLE_CLIENT_SECRET + GOOGLE_REDIRECT_URI
#    → Enables "Continue with Google"
#
# Note: Users can always register with email/password even without OAuth.
# =============================================================================
