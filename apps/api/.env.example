# PlanFlow API Environment Variables

# Server
PORT=3001
NODE_ENV=development

# Database (Neon PostgreSQL)
# Get your connection string from https://console.neon.tech
# Format: postgresql://[user]:[password]@[host]/[database]?sslmode=require
DATABASE_URL=postgresql://user:password@ep-example-123456.us-east-2.aws.neon.tech/planflow?sslmode=require

# Pooled connection (for serverless - uses connection pooling)
# Use the pooled connection string from Neon dashboard
DATABASE_URL_POOLED=postgresql://user:password@ep-example-123456-pooler.us-east-2.aws.neon.tech/planflow?sslmode=require

# JWT Authentication
# IMPORTANT: JWT_SECRET must be at least 32 characters for security
# Generate a secure secret: openssl rand -base64 48
# The server will NOT start with an insecure or missing JWT_SECRET
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=86400

# LemonSqueezy Payment Integration
# Get these from your LemonSqueezy dashboard: https://app.lemonsqueezy.com
LEMON_SQUEEZY_API_KEY=
LEMON_SQUEEZY_STORE_ID=
LEMON_SQUEEZY_PRO_VARIANT_ID=
LEMON_SQUEEZY_TEAM_VARIANT_ID=
LEMON_SQUEEZY_WEBHOOK_SECRET=

# Resend Email Service
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=
# Email address to send from (must be verified in Resend)
RESEND_FROM_EMAIL=PlanFlow <notifications@planflow.tools>

# Application URL (for email links)
APP_URL=http://localhost:3000

# GitHub OAuth Integration
# Create an OAuth App at: https://github.com/settings/developers
# Set Authorization callback URL to: http://localhost:3000/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:3000/auth/github/callback
# For webhook signature verification (optional)
GITHUB_WEBHOOK_SECRET=

# Redis Configuration (Optional)
# Redis is used for rate limiting across multiple server instances.
# If not configured, the API will fall back to in-memory rate limiting.
#
# Option 1: Connection URL (recommended for cloud providers like Upstash, Railway)
# Get your Redis URL from your cloud provider dashboard
# REDIS_URL=redis://default:password@hostname:6379
# or for Upstash:
# UPSTASH_REDIS_URL=rediss://default:password@hostname:6379
#
# Option 2: Individual connection parameters
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0
# REDIS_TLS=false
#
# Optional: Key prefix for Redis keys (defaults to "planflow:")
# REDIS_KEY_PREFIX=planflow:
