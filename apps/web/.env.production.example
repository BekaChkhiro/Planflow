# PlanFlow Web - Production Environment Variables
# Copy this file and set values in your deployment platform (Vercel, Railway, etc.)

# =============================================================================
# API CONFIGURATION
# =============================================================================
# Production API endpoint
NEXT_PUBLIC_API_URL=https://api.planflow.tools

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
NEXT_PUBLIC_APP_URL=https://app.planflow.tools
NEXT_PUBLIC_APP_NAME=PlanFlow

# =============================================================================
# WEBSOCKET CONFIGURATION
# =============================================================================
# WebSocket server URL (usually same as API but with wss://)
NEXT_PUBLIC_WS_URL=wss://api.planflow.tools

# =============================================================================
# ANALYTICS (PostHog)
# =============================================================================
# Get from https://app.posthog.com/project/settings
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# =============================================================================
# ERROR TRACKING (Sentry)
# =============================================================================
# Get DSN from https://sentry.io/settings/projects/
NEXT_PUBLIC_SENTRY_DSN=

# Auth token for source map upload (from https://sentry.io/settings/auth-tokens/)
SENTRY_AUTH_TOKEN=

# Organization slug and project name (from Sentry dashboard)
SENTRY_ORG=
SENTRY_PROJECT=

# =============================================================================
# PAYMENTS (LemonSqueezy)
# =============================================================================
# Store ID for checkout links
NEXT_PUBLIC_LEMONSQUEEZY_STORE_ID=

# =============================================================================
# PUSH NOTIFICATIONS (Web Push)
# =============================================================================
# Public VAPID key for browser push notifications
# Must match the VAPID_PUBLIC_KEY set in API .env
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# =============================================================================
# DEPLOYMENT CHECKLIST
# =============================================================================
# Required:
# ✅ NEXT_PUBLIC_API_URL (production API endpoint)
# ✅ NEXT_PUBLIC_APP_URL (production frontend URL)
# ✅ NEXT_PUBLIC_WS_URL (WebSocket endpoint, usually wss://api.domain.com)
#
# Recommended:
# ⬜ NEXT_PUBLIC_SENTRY_DSN (for error tracking)
# ⬜ SENTRY_AUTH_TOKEN + SENTRY_ORG + SENTRY_PROJECT (for source maps)
# ⬜ NEXT_PUBLIC_POSTHOG_KEY (for analytics)
#
# Optional:
# ⬜ NEXT_PUBLIC_LEMONSQUEEZY_STORE_ID (for payments)
# ⬜ NEXT_PUBLIC_VAPID_PUBLIC_KEY (for push notifications)
# =============================================================================
